{
  "name": "termwatch",
  "version": "1.0.0",
  "description": "Watch video content behind transparent terminal panels",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "audit": "npm audit --audit-level=high",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:perf": "node test/perf/benchmark.js",
    "licenses": "node scripts/generate-licenses.js",
    "icons": "node scripts/generate-icons.js",
    "version:bump": "node scripts/bump-version.js"
  },
  "author": "TermWatch",
  "license": "MIT",
  "dependencies": {
    "@lydell/node-pty": "1.2.0-beta.3",
    "@simonwep/pickr": "1.9.1",
    "@xterm/addon-canvas": "0.7.0",
    "@xterm/addon-clipboard": "0.1.0",
    "@xterm/addon-fit": "0.10.0",
    "@xterm/addon-web-links": "0.11.0",
    "@xterm/xterm": "5.5.0",
    "electron-log": "5.3.3",
    "electron-store": "8.2.0",
    "electron-updater": "^6.8.3",
    "tree-kill": "1.2.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.3",
    "@electron/rebuild": "4.0.4",
    "@playwright/test": "^1.52.0",
    "electron": "https://github.com/castlabs/electron-releases#v40.7.0+wvcus",
    "electron-builder": "25.1.8",
    "eslint": "^10.0.3",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-security": "^4.0.0",
    "electron-icon-builder": "^2.0.1",
    "happy-dom": "^20.8.3",
    "vitest": "^4.0.18"
  }
}
